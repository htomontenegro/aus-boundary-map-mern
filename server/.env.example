# ──────────────────────────────────────────────
# Australian Boundary Map — Server Environment
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# MongoDB connection string
# Local:   mongodb://localhost:27017/boundary_map
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/boundary_map
MONGO_URI=mongodb://localhost:27017/boundary_map

# JWT secret — must be at least 32 random characters
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# Port the Express server listens on
PORT=4001

# URL of the frontend (used for CORS)
CLIENT_URL=http://localhost:5174

# ──────────────────────────────────────────────
# Seed script settings (used by: npm run seed)
# ──────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
